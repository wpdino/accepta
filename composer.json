{
    "name": "wpdino/accepta",
    "type": "wordpress-theme",
    "description": "Accepta is a modern and flexible WordPress theme designed to help you create beautiful websites with ease.",
    "keywords": [
        "WordPress",
        "Themes"
    ],
    "homepage": "https://github.com/wpdino/accepta",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "WPDINO",
            "homepage": "https://wpdino.com"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7.0",
        "wptrt/wpthemereview": "^0.2.1",
        "php-parallel-lint/php-parallel-lint": "^1.2.0",
        "wp-cli/i18n-command": "^2.2.5"
    },
    "scripts": {
        "lint:wpcs": "@php ./vendor/squizlabs/php_codesniffer/bin/phpcs",
        "lint:php": "@php ./vendor/bin/parallel-lint --exclude .git --exclude vendor .",
        "make-pot": "wp i18n make-pot . languages/accepta.pot"
    },
    "support": {
        "issues": "https://github.com/wpdino/accepta/issues",
        "source": "https://github.com/wpdino/accepta"
    }
}
